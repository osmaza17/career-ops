# Secrets (never commit real values — use .env.example as template)
.env

# Generated / large auto-installed
node_modules/
bun.lock
package-lock.json
career-dashboard

# OS
.DS_Store
*.mov
*.mp4

# Claude Code local
.claude/settings.local.json
.claude/memory/

# Misc
.update-dismissed
.update-lock
.resolved-prompt-*

# Personal data and generated outputs (keep folder placeholders only)
/data/*
!/data/.gitkeep
/batch/tracker-additions/*
!/batch/tracker-additions/.gitkeep
/output/CVs/*
!/output/CVs/.gitkeep
/output/interview-prep/*
!/output/interview-prep/.gitkeep
/output/reports/*
!/output/reports/.gitkeep
